<?xml version="1.0" encoding="UTF-8"?>
<!-- San Francisco landmarks — authored for OnlyMapJS examples (public domain
     facts, our own file). Mixed geometry so the KML → GeoJSON demo shows
     Point, LineString and Polygon placemarks. -->
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>San Francisco landmarks</name>
    <Placemark>
      <name>Golden Gate Bridge</name>
      <description>Suspension bridge, opened 1937.</description>
      <Point><coordinates>-122.4783,37.8199,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Ferry Building</name>
      <description>Marketplace and ferry terminal on the Embarcadero.</description>
      <Point><coordinates>-122.3933,37.7955,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Coit Tower</name>
      <description>Art-deco tower atop Telegraph Hill.</description>
      <Point><coordinates>-122.4058,37.8024,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Painted Ladies</name>
      <description>Victorian houses at Alamo Square.</description>
      <Point><coordinates>-122.4329,37.7763,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Ocean Beach</name>
      <description>Pacific shoreline on the western edge.</description>
      <Point><coordinates>-122.5107,37.7594,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Market Street</name>
      <description>The city's main diagonal artery.</description>
      <LineString>
        <coordinates>
          -122.3937,37.7946,0 -122.4069,37.7844,0 -122.4194,37.7749,0 -122.4269,37.7694,0
        </coordinates>
      </LineString>
    </Placemark>
    <Placemark>
      <name>Golden Gate Park</name>
      <description>Large urban park stretching to the ocean.</description>
      <Polygon>
        <outerBoundaryIs><LinearRing>
          <coordinates>
            -122.5107,37.7749,0 -122.4544,37.7749,0 -122.4544,37.7716,0 -122.5107,37.7716,0 -122.5107,37.7749,0
          </coordinates>
        </LinearRing></outerBoundaryIs>
      </Polygon>
    </Placemark>
  </Document>
</kml>
